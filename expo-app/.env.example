# =============================================================================
# CLIENT (expo-app) — Only EXPO_PUBLIC_* below belong in this file.
# NEVER add server-only secrets here (e.g. SUPABASE_SERVICE_ROLE_KEY,
# GOOGLE_MAPS_API_KEY, RENTCAST_API_KEY, OPENAI_API_KEY, webhook secrets).
# Those go in Supabase Dashboard → Edge Functions → Secrets.
# Do not commit .env or .env.local; they are gitignored.
# =============================================================================

# Supabase — required for auth, portfolio, imports. Copy this file to .env and set real values.
# Project URL: Supabase Dashboard → Settings → API → Project URL (must be https://…supabase.co for release builds).
# Anon key: same page → anon public (long JWT starting with eyJ…). Never use the service role key in the app.
# Leave blank until filled; do not commit .env.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps Platform (Places, Geocoding) — backend/Edge Function only. Do not use EXPO_PUBLIC_.
# Set in Supabase Dashboard → Edge Functions → Secrets as GOOGLE_MAPS_API_KEY.
# GOOGLE_MAPS_API_KEY=your-google-api-key

# RentCast (rent estimates/comps) — backend/Edge Function only. Set in Supabase Edge Function Secrets.
# RENTCAST_API_KEY=your-rentcast-api-key

# OpenAI (summaries, explanations) — backend/Edge Function only. Set in Supabase Edge Function Secrets.
# OPENAI_API_KEY=your-openai-api-key

# Census API (Future Value Predictor, market data) — backend/Edge Function only. Set in Supabase Edge Function Secrets.
# CENSUS_API_KEY=your-census-api-key

# Stripe — payments and subscriptions. See docs/STRIPE-SETUP.md and docs/SERVICES-INITIATION-GUIDE.md §8.
# Publishable key: safe for client (use only when you add payment UI).
# EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Secret key and webhook secret: backend/Edge Function only. Set in Supabase Edge Function Secrets.
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# RevenueCat — in-app subscriptions (iOS). Required for paywall/purchase on device.
# Get key from RevenueCat Dashboard → Project → API Keys → Public app-specific (iOS).
# Product IDs, entitlement, and offering IDs: see src/config/billing.ts (insert dashboard values there).
# EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=appl_xxx

# Legal and support (optional). URLs linked from Settings and Paywall.
# Defaults: https://prop-folio.vercel.app/privacy, /terms, /support. Support URL should match App Store Connect.
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://prop-folio.vercel.app/privacy
# EXPO_PUBLIC_TERMS_URL=https://prop-folio.vercel.app/terms
# EXPO_PUBLIC_SUPPORT_URL=https://prop-folio.vercel.app/support
# EXPO_PUBLIC_BILLING_HELP_URL=https://yoursite.com/billing-help

# QA diagnostics panel (optional). Set to true for internal QA/TestFlight builds to show release readiness diagnostics in Settings.
# EXPO_PUBLIC_ENABLE_QA_DIAGNOSTICS=true

# Crash reporting: the app uses Firebase Crashlytics (@react-native-firebase/crashlytics), not Sentry.
# Do not add EXPO_PUBLIC_SENTRY_DSN here — it is ignored and confuses onboarding.

# Firebase (iOS Crashlytics) — not an EXPO_PUBLIC_* API key. The plist identifies your Firebase iOS app to the SDK.
# Local dev / prebuild: place GoogleService-Info.plist in expo-app/ (see expo-app/docs/MONITORING_SETUP.md).
# EAS cloud builds: create a file-type env var GOOGLE_SERVICES_INFO_PLIST in Expo — see repo root FIREBASE_CRASHLYTICS_MANUAL_STEPS.md.
# Do not paste plist contents into .env; use the real file or EAS file upload only.
