{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "description": "PropFolio iOS app (Expo). Production builds are iOS-only; no android or web scripts.",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "test": "node node_modules/jest/bin/jest.js --rootDir .",
    "test:watch": "node node_modules/jest/bin/jest.js --rootDir . --watch",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "lint": "node node_modules/expo/bin/cli lint",
    "expo:config": "node node_modules/expo/bin/cli config",
    "expo:config:json": "node node_modules/expo/bin/cli config --json",
    "validate": "npm run typecheck && npm run test",
    "eas:build:ios": "npx eas-cli@^18.4.0 build --platform ios --profile production",
    "eas:submit:ios": "npx eas-cli@^18.4.0 submit --platform ios --latest --profile production",
    "eas:release:ios": "npx eas-cli@^18.4.0 build --platform ios --profile production --auto-submit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/native": "^7.1.28",
    "@sentry/react-native": "^8.4.0",
    "@supabase/supabase-js": "^2.49.1",
    "expo": "~55.0.6",
    "expo-constants": "~55.0.7",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.5",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-web-browser": "~55.0.9",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-maps": "^1.27.2",
    "react-native-purchases": "^9.12.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
