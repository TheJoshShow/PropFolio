{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "description": "PropFolio iOS app (Expo). Production builds are iOS-only; no android or web scripts.",
  "scripts": {
    "eas-build-pre-install": "node scripts/eas-build-pre-install.mjs",
    "eas-build-post-install": "node scripts/verify-eas-production-client-env.mjs",
    "expo-cli": "node node_modules/expo/bin/cli",
    "start": "node node_modules/expo/bin/cli start",
    "ios": "node node_modules/expo/bin/cli start --ios",
    "test": "node node_modules/jest/bin/jest.js --rootDir .",
    "test:open-handles": "node node_modules/jest/bin/jest.js --rootDir . --detectOpenHandles --runInBand",
    "test:watch": "node node_modules/jest/bin/jest.js --rootDir . --watch",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "lint": "node node_modules/expo/bin/cli lint",
    "expo:config": "node node_modules/expo/bin/cli config",
    "expo:config:json": "node node_modules/expo/bin/cli config --json",
    "verify:firebase-config": "node scripts/verify-expo-firebase-config.mjs",
    "verify:firebase-config:strict": "node scripts/verify-expo-firebase-config.mjs --strict",
    "validate": "npm run typecheck && npm run test",
    "eas:build:ios": "npx eas-cli@^18.4.0 build --platform ios --profile production",
    "eas:submit:ios": "npx eas-cli@^18.4.0 submit --platform ios --latest --profile production",
    "eas:release:ios": "npx eas-cli@^18.4.0 build --platform ios --profile production --auto-submit"
  },
  "dependencies": {
    "@expo/log-box": "^55.0.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-firebase/crashlytics": "^23.8.8",
    "@react-navigation/native": "^7.1.28",
    "@supabase/supabase-js": "^2.49.1",
    "expo": "~55.0.9",
    "expo-build-properties": "~55.0.10",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "^55.0.19",
    "expo-font": "~55.0.4",
    "expo-linking": "^55.0.9",
    "expo-router": "^55.0.8",
    "expo-splash-screen": "^55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-web-browser": "~55.0.10",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "^0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-maps": "^1.27.2",
    "react-native-purchases": "^9.12.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
