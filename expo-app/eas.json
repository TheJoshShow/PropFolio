{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "environment": "development",
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "environment": "preview",
      "distribution": "internal"
    },
    "production": {
      "environment": "production",
      "autoIncrement": true,
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "${EXPO_PUBLIC_SUPABASE_URL}",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "${EXPO_PUBLIC_SUPABASE_ANON_KEY}",
        "EXPO_PUBLIC_REVENUECAT_API_KEY_IOS": "${EXPO_PUBLIC_REVENUECAT_API_KEY_IOS}",
        "EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID": "${EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID}",
        "IOS_GOOGLE_MAPS_API_KEY": "${IOS_GOOGLE_MAPS_API_KEY}"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6760779180",
        "appleTeamId": "C7UKTVM956",
        "ascApiKeyPath": "${ASC_API_KEY_PATH}",
        "ascApiKeyIssuerId": "59955ad5-ae42-4790-b99c-e82fdf7d43f1",
        "ascApiKeyId": "X7KSRJU37Z"
      }
    }
  }
}
