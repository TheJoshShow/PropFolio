# Copy to `.env` for local development. Restart Metro after changes.
# Client-safe keys only (EXPO_PUBLIC_*). RentCast + OpenAI stay in Supabase secrets.

# Supabase — Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# After setting these, configure redirect URLs in Supabase (see docs/AUTH_DEVELOPER_CHECKLIST.md).

# RevenueCat — public SDK keys (iOS = Apple App Store, Android = Google Play)
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=
# Offering identifiers (must match RevenueCat dashboard → Offerings)
EXPO_PUBLIC_RC_SUBSCRIPTION_OFFERING_ID=propfolio_subscription
EXPO_PUBLIC_RC_CREDITS_OFFERING_ID=propfolio_credits

# Legal & support (replace example.com before production)
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://example.com/propfolio/privacy
EXPO_PUBLIC_TERMS_OF_SERVICE_URL=https://example.com/propfolio/terms
EXPO_PUBLIC_SUPPORT_EMAIL=support@example.com

# Optional: only if you call Google from the client elsewhere. Import uses Edge Functions instead.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Supabase Edge Function secrets (Dashboard → Project Settings → Edge Functions → Secrets) ---
# Do NOT put these in Expo .env — set as secrets for deployed functions + `supabase secrets set` locally.
# SUPABASE_URL — same as EXPO_PUBLIC_SUPABASE_URL (Edge runtime injects automatically in hosted env).
# SUPABASE_ANON_KEY — anon key (Edge injects in hosted env).
# SUPABASE_SERVICE_ROLE_KEY — service role; revenuecat-webhook only. Never ship to the client.
# GOOGLE_MAPS_API_KEY — Places API (New): Autocomplete + Place Details; Geocoding for normalize-address.
# RENTCAST_API_KEY — RentCast `X-Api-Key` for import-property and rent-estimate.
# OPENAI_API_KEY — generate-property-summary narrative only (no metric math).
# OPENAI_SUMMARY_MODEL — optional override (default gpt-4o-mini).
# REVENUECAT_WEBHOOK_SECRET — Bearer token RevenueCat sends; must match Authorization header on webhook.
