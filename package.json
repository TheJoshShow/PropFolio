{
  "name": "propfolio",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy:supabase:db": "npx supabase db push",
    "deploy:supabase:functions": "npx supabase functions deploy",
    "deploy:supabase:db:dry": "npx supabase db push --dry-run",
    "eas:build:ios": "npx eas-cli build --platform ios --profile production",
    "eas:build:ios:preview": "npx eas-cli build --platform ios --profile preview",
    "eas:submit:ios": "npx eas-cli submit --platform ios --profile production --latest",
    "eas:release:ios": "npx eas-cli build --platform ios --profile production --wait && npx eas-cli submit --platform ios --profile production --latest"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.101.1",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.33",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-purchases": "^9.15.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.3",
    "eas-cli": "^18.5.0",
    "typescript": "~5.9.2",
    "vitest": "^3.2.4"
  },
  "private": true
}
